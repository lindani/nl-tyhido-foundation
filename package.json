{
  "name": "nl-tyhido-foundation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "NL Tyhido Foundation - Full Stack Application",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "import-images": "node convert_images.js",
    "create-video": "node create-hero-video.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "heic-convert": "^2.1.0",
    "sharp": "^0.34.5"
  }
}
